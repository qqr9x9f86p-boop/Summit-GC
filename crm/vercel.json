{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(config|crm|firebase-init)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/crm.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
