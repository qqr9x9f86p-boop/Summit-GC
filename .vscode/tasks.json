{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto-Push to GitHub",
      "type": "shell",
      "command": "bash auto-push.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "label": "Auto-Push",
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": []
    }
  ]
}
